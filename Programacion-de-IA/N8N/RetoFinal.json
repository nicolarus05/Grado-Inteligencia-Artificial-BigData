    {
      "parameters": {
        "jsCode": "const body = $input.first().json;\nconst ts = body.current_weather?.time;\nconst temp = body.current_weather?.temperature;\nconst windspeed = body.current_weather?.windspeed;\nconst idx = body.hourly.time.indexOf(ts);\nconst humidity = idx !== -1 ? body.hourly.relativehumidity_2m[idx] : null;\n\nif (!ts || temp === undefined) throw new Error('Datos incompletos desde Open-Meteo');\nif (temp < -50 || temp > 60) throw new Error('Temperatura fuera de rango: ' + temp);\n\nreturn [{ json: {\n  city: 'Motril',\n  ts: ts,\n  temp_c: temp,\n  humidity_pct: humidity,\n  windspeed_kmh: windspeed,\n  fetched_at: new Date().toISOString()\n}}];"
      },
      "id": "fed7cf05-a772-403a-84a4-72e98321016b",
