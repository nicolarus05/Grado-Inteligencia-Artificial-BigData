    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO weather_reto (city, ts, temp_c, humidity_pct, windspeed_kmh, fetched_at)\nVALUES (\n  '{{ $json.city }}',\n  '{{ $json.ts }}'::timestamp,\n  {{ $json.temp_c }}::numeric,\n  {{ $json.humidity_pct === null ? 'NULL' : $json.humidity_pct }},\n  {{ $json.windspeed_kmh }}::numeric,\n  '{{ $json.fetched_at }}'::timestamptz\n)\nON CONFLICT (city, ts) DO NOTHING;\n",
        "options": {}
      },
