# Variables para el despliegue local de n8n (clase)
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8npass
POSTGRES_DB=n8n

# Usuario/clave para entrar al editor de n8n
N8N_BASIC_AUTH_USER=student
N8N_BASIC_AUTH_PASSWORD=n8n1234

# IMPORTANTE: clave de cifrado de credenciales en n8n (mínimo 32 caracteres)
# No la cambiéis una vez guardéis credenciales.
N8N_ENCRYPTION_KEY=pon-aqui-una-clave-larga-y-unica-para-la-clase-123456
